# Supabase public keys for client usage (used in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase server key (service role) for migrations / server-only operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional override for Supabase storage public URL (used in admin file list links)
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public
